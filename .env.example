# Supabase project (Settings -> API in the Supabase dashboard)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Signs login session cookies (any long random string)
SESSION_SECRET=change-me

# Claude API key for the AI Builder + Custom Design (claude-sonnet-5 for page
# designs, claude-haiku-4-5 for content and chat edits). Without it everything
# runs in sample mode (placeholder content, no API calls).
ANTHROPIC_API_KEY=
# Force sample mode even with a key set (useful while testing):
# AI_BUILDER_MOCK=1
# Use Sonnet for chat edits too (default is Haiku):
# AI_EDIT_MODEL=claude-sonnet-5

# Domains
# The root domain that managed scorecard subdomains hang off:
#   <slug>.accesoai.com.au -> the scorecard whose Settings->Domain slug matches
PUBLIC_BASE_DOMAIN=accesoai.com.au
# The exact host the platform/dashboard itself runs on (so it is never
# mistaken for a scorecard subdomain):
PUBLIC_APP_HOST=score.accesoai.com.au

# Legacy: previously protected /admin; now only used as a fallback SESSION_SECRET
ADMIN_PASSWORD=change-me
