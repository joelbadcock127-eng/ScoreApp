# Supabase project (Settings -> API in the Supabase dashboard)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Signs login session cookies (any long random string)
SESSION_SECRET=change-me

# Claude API key for the AI Builder (uses claude-haiku-4-5).
# Without it the builder runs in sample mode (placeholder content, no API calls).
ANTHROPIC_API_KEY=
# Force sample mode even with a key set (useful while testing):
# AI_BUILDER_MOCK=1

# Legacy: previously protected /admin; now only used as a fallback SESSION_SECRET
ADMIN_PASSWORD=change-me
